<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="FlutterSecureStorage" />
        <exclude domain="sharedpref" path="FlutterSecureStorageConfiguration" />
        <exclude domain="sharedpref" path="FlutterSharedPreferences" />
        <exclude
            domain="file"
            path="datastore/FlutterSharedPreferences.preferences_pb" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="FlutterSecureStorage" />
        <exclude domain="sharedpref" path="FlutterSecureStorageConfiguration" />
        <exclude domain="sharedpref" path="FlutterSharedPreferences" />
        <exclude
            domain="file"
            path="datastore/FlutterSharedPreferences.preferences_pb" />
    </device-transfer>
</data-extraction-rules>
